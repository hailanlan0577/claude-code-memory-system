+    @staticmethod
+    def _fix_json_text(text: str) -> str:
+        """Fix concatenated JSON objects from non-OpenAI providers like qwen-plus."""
+        text = text.strip()
+        try:
+            json.loads(text)
+            return text
+        except json.JSONDecodeError:
+            pass
+
+        # Split concatenated top-level JSON objects by tracking brace depth
+        objects: list[str] = []
+        depth = 0
+        start = 0
+        in_string = False
+        escape = False
+
+        for i, ch in enumerate(text):
+            if escape:
+                escape = False
+                continue
+            if ch == '\\':
+                escape = True
+                continue
+            if ch == '"':
+                in_string = not in_string
+                continue
+            if in_string:
+                continue
+            if ch == '{':
+                if depth == 0:
+                    start = i
+                depth += 1
+            elif ch == '}':
+                depth -= 1
+                if depth == 0:
+                    objects.append(text[start:i + 1])
+
+        if len(objects) > 1:
+            return '[' + ', '.join(objects) + ']'
+
+        return text
